using Gtk 4.0;
using Adw 1;

template $NorkaWindow : Adw.ApplicationWindow {
  default-width: 1000;
  default-height: 800;
  width-request: 360;
  height-request: 360;

  title: _("Norka");

  Adw.Breakpoint breakpoint {}

  Adw.NavigationSplitView split_view {

      [sidebar]
      $SidebarPage sidebar_page {
        name: "sidebar";
        title: "Sidebar";
      }

      [content]
      $ContentPage content_page {
        name: "content_page";
        title: "Content";
      }
  }
}
